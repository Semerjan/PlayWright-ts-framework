{
  "name": "playwright-ts-framework",
  "version": "1.0.0",
  "description": "A Modern Playwright Test Automation Framework with TypeScript, Page Object Model, and GitHub Actions CI/CD",
  "keywords": ["playwright", "typescript", "automation", "testing", "e2e", "api-testing", "github-actions", "page-object-model"],
  "homepage": "https://github.com/YOUR_USERNAME/playwright-ts-framework",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium",
    "test:ui:firefox": "playwright test --project=ui-firefox",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:headed": "playwright test --headed --project=ui-chromium",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
